# ── Datenbank ────────────────────────────────────────────────
POSTGRES_DB=idlevolution
POSTGRES_USER=idle
POSTGRES_PASSWORD=change-me

# ── App ──────────────────────────────────────────────────────
APP_PORT=8420
TICK_SECONDS=5
PERSIST_EVERY_TICKS=12
OFFLINE_CAP_HOURS=24

# Token, mit dem der ai-worker (und nur er) /api/ai/* aufrufen darf
AI_IMPORT_TOKEN=change-me-too

# ── Lokaler LLM-Server (llama.cpp / llama-swap) ──────────────
LLM_BASE_URL=http://localhost:8080
LLM_MODEL=gemma4-12b
LLM_CTX=32768
# Großzügig bemessen: Reasoning-Modelle denken erst (reasoning_content), dann kommt das JSON
LLM_MAX_TOKENS=12288
LLM_TEMPERATURE=0.7

# Nächtliche Generierung (Cron-Syntax) + sofortiger Lauf beim Start (Debug)
AI_CRON=0 3 * * *
AI_RUN_ON_START=false
