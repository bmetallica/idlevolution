{
  "$id": "event",
  "type": "object",
  "required": ["id", "name", "durationTicks", "modifiers"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,40}$" },
    "name": {
      "type": "object",
      "required": ["de"],
      "additionalProperties": { "type": "string", "maxLength": 80 }
    },
    "description": {
      "type": "object",
      "additionalProperties": { "type": "string", "maxLength": 500 }
    },
    "icon": { "type": "string", "maxLength": 8 },
    "epoch": { "type": "string" },
    "durationTicks": { "type": "integer", "minimum": 1, "maximum": 100000 },
    "modifiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "production": {
          "type": "object",
          "propertyNames": { "pattern": "^([a-z][a-z0-9_]{1,40}|\\*)$" },
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 10 }
        },
        "grant": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      }
    },
    "meta": { "type": "object" }
  }
}
