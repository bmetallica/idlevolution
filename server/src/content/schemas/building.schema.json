{
  "$id": "building",
  "type": "object",
  "required": ["id", "name", "category", "epoch", "cost"],
  "additionalProperties": false,
  "$defs": {
    "resourceMap": {
      "type": "object",
      "propertyNames": { "pattern": "^([a-z][a-z0-9_-]{1,80}|\\*)$" },
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1000000 }
    }
  },
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{1,80}$" },
    "name": {
      "type": "object",
      "required": ["de"],
      "additionalProperties": { "type": "string", "maxLength": 80 }
    },
    "description": {
      "type": "object",
      "additionalProperties": { "type": "string", "maxLength": 500 }
    },
    "category": { "enum": ["production", "storage", "housing", "civic"] },
    "epoch": { "type": "string" },
    "icon": { "type": "string", "maxLength": 8 },
    "cost": { "$ref": "#/$defs/resourceMap" },
    "buildTimeTicks": { "type": "integer", "minimum": 0, "maximum": 10000 },
    "workers": { "type": "integer", "minimum": 0, "maximum": 1000 },
    "production": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "inputs": { "$ref": "#/$defs/resourceMap" },
        "outputs": { "$ref": "#/$defs/resourceMap" }
      }
    },
    "storage": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/resourceMap" }]
    },
    "housing": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "capacity": { "type": "integer", "minimum": 1, "maximum": 10000 }
      }
    },
    "requires": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "epoch": { "type": "string" },
        "buildings": { "$ref": "#/$defs/resourceMap" },
        "resources": { "$ref": "#/$defs/resourceMap" },
        "population": { "type": "number", "minimum": 0 }
      }
    },
    "placement": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "terrain": {
          "type": "array",
          "items": { "enum": ["grass", "sand", "forest", "rock"] },
          "minItems": 1
        },
        "adjacent": {
          "type": "object",
          "propertyNames": { "enum": ["grass", "sand", "forest", "rock", "water"] },
          "additionalProperties": { "type": "integer", "minimum": 1, "maximum": 8 }
        },
        "size": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "w": { "type": "integer", "minimum": 1, "maximum": 4 },
            "h": { "type": "integer", "minimum": 1, "maximum": 4 }
          }
        }
      }
    },
    "maxCount": { "type": ["integer", "null"], "minimum": 1 },
    "meta": { "type": "object" }
  }
}
